# Wallet private key (gets from MetaMask)
PRIVATE_KEY=

# Shared encryption key for the photo
ENCRYPTION_KEY=

# Base RPC (default works, or use your own)
BASE_RPC=https://mainnet.base.org

# Testnet (deploy here first to test)
# BASE_SEPOLIA_RPC=https://sepolia.base.org

# Contract address (filled after deploy step)
CONTRACT_ADDRESS=

# Wallet address receiving the tokens (Ahmed's address)
RECIPIENT=

# Pinata JWT for IPFS uploads (https://app.pinata.cloud/developers/api-keys)
PINATA_JWT=

# Basescan API key for contract verification (optional)
BASESCAN_API_KEY=
